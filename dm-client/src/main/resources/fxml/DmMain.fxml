<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/fxml/1"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="15"
      prefWidth="1600"
      prefHeight="900"
      style="-fx-background-color: #1f2937;">

    <!-- Заголовок -->
    <Label text="Avalon — DM Tool"
           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <!-- Создание сессии -->
    <HBox spacing="10">
        <TextField fx:id="sessionNameField"
                   promptText="Название сессии (опционально)"
                   prefWidth="300"/>
        <Button fx:id="createSessionBtn"
                text="Создать новую сессию"
                style="-fx-font-weight: bold;"/>
    </HBox>

    <!-- Кнопки управления -->
    <HBox spacing="10">
        <Button fx:id="loadMapBtn" text="Загрузить карту"/>
        <Button fx:id="addTokenBtn" text="Добавить токен"/>
        <Button fx:id="revealAllBtn" text="Снять весь туман войны"/>
    </HBox>

    <Label text="Карта поля боя (DM видит всё)"
           style="-fx-font-size: 16; -fx-text-fill: #a1a1aa;"/>

    <!-- Область для карты -->
    <ScrollPane fitToWidth="true" fitToHeight="true" prefHeight="600">
        <Pane fx:id="canvasContainer" prefWidth="1400" prefHeight="900"/>
    </ScrollPane>

    <Label fx:id="statusLabel"
           text="Статус: отключено"
           style="-fx-text-fill: #f59e0b;"/>
</VBox>